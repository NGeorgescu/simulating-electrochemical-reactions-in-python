# Python virtual environment (rebuild with: python3 -m venv .venv && .venv/bin/pip install -r requirements.txt)
.venv/

# Byte-compiled / caches
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# Jupyter
.jupyter/
*.nbconvert.ipynb

# Generated Mathematica-notebook text dumps (tools/nb_extract.py)
tools/_extracted_*.txt

# Non-redistributed experimental data (e.g. ch16 BAS 100B files from the book's CD).
# Drop local copies under data/chapter16/ to enable the optional real-data sections;
# they must never be committed (the repo license covers only the Python port).
data/

# OS / editor
.DS_Store
*~
.vscode/
.idea/
